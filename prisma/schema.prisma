generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 사용자 계정
model User {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  password    String   // bcrypt hashed
  name        String
  role        String   @default("EMPLOYEE") // "ADMIN" | "EMPLOYEE" | "EXECUTIVE"
  pendingRole String?  // 승인 대기 중인 역할 (e.g. "ADMIN")
  employee    Employee?
  createdAt   DateTime @default(now())
}

// 본사/현장 구분
model Location {
  id      Int      @id @default(autoincrement())
  company String   // "남광토건" | "극동건설" | "금광기업"
  name    String   // e.g. "본사", "서울현장", "부산현장"
  type       String     // "HQ" | "SITE"
  teams      Team[]
  categories Category[]
}

// 팀
model Team {
  id          Int       @id @default(autoincrement())
  name        String    // e.g. "경영지원팀", "설계팀"
  description String?   // 팀 설명 (최대 3줄)
  imageUrl    String?   // 팀 대표 이미지 URL
  imageStyle  String?   // 이미지 스타일 JSON (scale, x, y)
  category    String?   // 카테고리: 건축사업본부, 토목사업본부, 경영지원실, 기타
  locationId  Int
  location    Location  @relation(fields: [locationId], references: [id])
  employees   Employee[]
}

// 본부 (카테고리)
model Category {
  id         Int      @id @default(autoincrement())
  name       String   // e.g. "건축사업본부", "토목사업본부"
  company    String   // "남광토건" | "극동건설" | "금광기업" | "3사 통합관리"
  locationId Int      // 소속 ID (본사/현장)
  location   Location @relation(fields: [locationId], references: [id])

  @@unique([name, locationId])
}

// [보안] 감사 로그
model AuditLog {
  id         Int      @id @default(autoincrement())
  action     String   // "CREATE" | "UPDATE" | "DELETE" | "LOGIN" | "ROLE_CHANGE" 등
  userId     Int      // 수행한 사용자 ID
  targetType String   // "Employee" | "Team" | "User" | "Location"
  targetId   Int      // 대상 레코드 ID
  detail     String?  // 추가 상세 정보 (JSON)
  createdAt  DateTime @default(now())
}

// 직원
model Employee {
  id             Int      @id @default(autoincrement())
  name           String
  nameEn         String?  // 영어 이름
  email          String   @unique
  phone          String?
  phoneWork      String?  // 회사 번호
  emailWork      String?  // 회사 이메일
  position       String   // 직급: 사원, 대리, 과장, 차장, 부장
  role           String   // 직책: 팀원, 팀장, 부서장
  teamId         Int
  team           Team     @relation(fields: [teamId], references: [id])
  resumePath     String?  // 이력서 PDF 파일 경로
  photoUrl       String?  // 프로필 사진 URL
  joinDate       String?  // 입사일
  resumeData     String?  // 이력서 추출 데이터 (JSON)
  status         String   @default("ACTIVE") // "ACTIVE" | "INACTIVE"
  userId         Int?     @unique
  user           User?    @relation(fields: [userId], references: [id])
  // 기본 인사정보 추가 필드
  birthDate      String?  // 생년월일
  address        String?  // 주소
  jobCategory    String?  // 직종 (예: 건축)
  jobRole        String?  // 직무 (예: 공사관리)
  employmentType String?  // 직원구분 (예: 일반직)
  entryType      String?  // 입사경위
  specialty      String?  // 특기
  hobby          String?  // 취미
  taskDetail     String?  // 상세 업무
  skills         String?  // 스킬 (콤마 구분)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
